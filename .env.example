# Server Configuration
PORT=3001

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/aqua-talent

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email Configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_FROM_EMAIL=Your App <noreply@yourdomain.com>
EMAIL_ENABLED=true

# AWS S3 Configuration (Bucketeer)
BUCKETEER_AWS_REGION=us-east-1
BUCKETEER_BUCKET_NAME=your-bucket-name
BUCKETEER_AWS_ACCESS_KEY_ID=your-access-key-id
BUCKETEER_AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Password Reset Configuration
ADMIN_EMAIL=admin@yourdomain.com
FRONTEND_URL=http://localhost:3000

# Razorpay Payment Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

